# Database Configuration
# For local development, omit this or use SQLite
# For Supabase PostgreSQL production:
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Frontend Configuration
FRONTEND_URL=http://localhost:5173

# Authentication
SECRET_KEY=replace_with_strong_secret_key

# Email Configuration
# Use "resend" in Render, or "smtp" for local SMTP development.
EMAIL_PROVIDER=resend
RESEND_API_KEY=
SMTP_FROM_EMAIL=onboarding@resend.dev
SMTP_FROM_NAME=ClassNest

# SMTP fallback (required only when EMAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
